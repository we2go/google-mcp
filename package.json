{
  "name": "google-sheet-mcp",
  "version": "2.1.2",
  "description": "Connect Google Sheets & Docs to Cursor, VS Code, Claude Code and AI agents in 3 minutes. MCP Server + CLI installer.",
  "keywords": [
    "google-sheets",
    "google-docs",
    "mcp",
    "model-context-protocol",
    "cursor",
    "vscode",
    "claude",
    "ai-agent",
    "spreadsheet",
    "document",
    "data-source"
  ],
  "license": "MIT",
  "author": "MUST Dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/we2go/google-mcp.git"
  },
  "type": "module",
  "main": "./src/server/server.mjs",
  "bin": {
    "google-mcp": "src/cli/cli.mjs",
    "google-sheet-mcp": "src/cli/cli.mjs"
  },
  "files": [
    "src/",
    "examples/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/server/server.mjs",
    "init": "node src/cli/cli.mjs init",
    "test": "node src/cli/cli.mjs test",
    "list": "node src/cli/cli.mjs list",
    "read": "node src/cli/cli.mjs read",
    "docs-list": "node src/cli/cli.mjs docs-list",
    "docs-read": "node src/cli/cli.mjs docs-read",
    "docs-create": "node src/cli/cli.mjs docs-create",
    "prepublishOnly": "echo 'Ready to publish'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "commander": "^13.1.0",
    "googleapis": "^148.0.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0",
    "inquirer": "^12.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
